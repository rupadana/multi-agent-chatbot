# Salin file ini menjadi .env lalu sesuaikan nilainya.

# Default provider LLM (OpenAI-compatible). Bisa dioverride per-agent dari UI.
# Contoh base URL:
#   OpenAI       -> https://api.openai.com/v1
#   OpenRouter   -> https://openrouter.ai/api/v1
#   Together AI  -> https://api.together.xyz/v1
#   Ollama lokal -> http://localhost:11434/v1
#   LM Studio    -> http://localhost:1234/v1
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-xxxxx
LLM_MODEL=gpt-4o-mini

# Lokasi database SQLite
DATABASE_URL=sqlite:///./chatbot.db

# Origin frontend yang diizinkan (CORS), pisahkan dengan koma
CORS_ORIGINS=http://localhost:3000

# Autentikasi JWT — WAJIB diganti dengan string acak yang panjang di produksi.
# Contoh membuat: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=ubah-secret-ini-di-produksi-please-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# URL publik backend ini, dipakai untuk menyusun URL webhook integrasi
# (WhatsApp/WAHA, Telegram). Mis. https://bot.contoh.com — tanpa trailing slash.
# Kosongkan bila tidak memakai integrasi atau ingin konfigurasi webhook manual.
PUBLIC_BASE_URL=
