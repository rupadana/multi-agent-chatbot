# Salin file ini menjadi .env lalu isi nilai berikut.

# API key dari https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Model Claude yang dipakai (default: claude-opus-4-8)
CLAUDE_MODEL=claude-opus-4-8

# Lokasi database SQLite
DATABASE_URL=sqlite:///./chatbot.db

# Origin frontend yang diizinkan (CORS), pisahkan dengan koma
CORS_ORIGINS=http://localhost:3000
